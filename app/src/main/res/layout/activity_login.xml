<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".view.LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/logo_aplikasi"
            android:background="@drawable/bg_edit_text"
            android:backgroundTint="#EEF2F6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lapor_kampus"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#0055A5"
            android:letterSpacing="0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/laporkan_kerusakan_fasilitas_demi_kenyamanan_bersama"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="36dp"
            android:lineSpacingMultiplier="1.2" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="#64748B">

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Alamat Email"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:inputType="textEmailAddress"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:textSize="15sp"
                android:autofillHints="emailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:hintEnabled="false"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#64748B"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="#64748B">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/password_minimal_8_karakter"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:inputType="textPassword"
                android:paddingStart="48dp"
                android:textSize="15sp"
                android:autofillHints="password" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/masuk"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0055A5"
            app:cornerRadius="12dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvToRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/belum_punya_akun_daftar_di_sini"
            android:textColor="#0055A5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>