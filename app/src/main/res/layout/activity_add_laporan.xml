<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF"
    tools:context=".view.AddLaporanActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buat Laporan"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#0055A5"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Masukkan detail kerusakan fasilitas kampus dengan benar"
            android:textSize="14sp"
            android:textColor="#64748B"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Judul Laporan / Kerusakan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:hintEnabled="false">

            <EditText
                android:id="@+id/etAddJudul"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Contoh: AC Ruang 302 Mati"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:inputType="text"
                android:padding="16dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lokasi Fasilitas"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:hintEnabled="false">

            <EditText
                android:id="@+id/etAddLokasi"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edit_text"
                android:hint="Contoh: Gedung GKB Lt.3"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:inputType="text"
                android:padding="16dp"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Foto Bukti Kerusakan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnAmbilFoto"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Buka Kamera / Ambil Foto"
                android:textColor="#0055A5"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#E0F2FE"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPreviewFoto"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivPreviewFoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Pratinjau Foto Bukti" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <Button
            android:id="@+id/btnKirimLaporan"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Kirim Laporan"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0055A5"
            app:cornerRadius="12dp"
            android:elevation="4dp"/>

    </LinearLayout>
</ScrollView>